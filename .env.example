# =============================
# Google Sheets API
# =============================
# GCPのサービスアカウントJSONキーの内容をそのまま貼り付け
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# 操作対象のスプレッドシートID（URLの/d/と/editの間の文字列）
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# =============================
# NextAuth.js 認証
# =============================
NEXTAUTH_SECRET=your-random-secret-32chars-minimum
NEXTAUTH_URL=http://localhost:3000

# 利用を許可するGoogleアカウントのメールアドレス（カンマ区切り）
ALLOWED_EMAILS=you@gmail.com,teammate@gmail.com

# Google OAuth (GCPのOAuth 2.0クライアントID)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================
# Redis (Bull キュー用)
# =============================
# Render の Redis URL (本番) / ローカルは redis://localhost:6379
REDIS_URL=redis://localhost:6379

# =============================
# 送信設定
# =============================
# 1日の最大送信件数
DAILY_SEND_LIMIT=50
# 送信間隔の最小秒数
SEND_INTERVAL_MIN=30
# 送信間隔の最大秒数
SEND_INTERVAL_MAX=180

# =============================
# Slack通知 (任意)
# =============================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# =============================
# Serper.dev（サイト収集用Google検索API）
# =============================
# https://serper.dev でAPIキーを取得
SERPER_API_KEY=your_serper_api_key_here
